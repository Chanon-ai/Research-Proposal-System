# Docker compose overrides (optional)
PORT=8081
MONGODB=mongodb://mongo:27017/IAM
# Alternative backend keys (optional)
# MONGO_URI=mongodb://mongo:27017/IAM
# MONGODB_URI=mongodb://mongo:27017/IAM
# DATABASE_URL=mongodb://mongo:27017/IAM
# DB_URI=mongodb://mongo:27017/IAM
#
# Or split database parts
# DB_HOST=mongo
# DB_PORT=27017
# DB_NAME=IAM
# DB_USER=
# DB_PASS=
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend build-time variables
VUE_APP_API_BASE_URL=http://localhost:8081
VUE_APP_API_URL=http://localhost:8081
VUE_APP_CLIENTID=
VUE_APP_SCOPE=profile email
VUE_APP_PROMPT=select_account
