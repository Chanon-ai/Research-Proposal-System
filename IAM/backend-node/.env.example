# Core server
PORT=8081
NODE_ENV=dev
BASE_SERVER_URL=https://researchproposal.mfu.ac.th
KEY=change-me
TIMEOUT=500000
TOKENLANGTH=32
TOKENEXPIRED=30
TRANSACTIONEXPIRED=10

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# Mongo request log transport
MONGO_LOG_ENABLED=true

# Database
MONGODB=mongodb://mongo:27017/IAM
# Alternative URI names (supported):
# MONGO_URI=mongodb://mongo:27017/IAM
# MONGODB_URI=mongodb://mongo:27017/IAM
# DATABASE_URL=mongodb://mongo:27017/IAM
# DB_URI=mongodb://mongo:27017/IAM
#
# Or build URI from parts (supported):
# DB_HOST=mongo
# DB_PORT=27017
# DB_NAME=IAM
# DB_USER=
# DB_PASS=
# DB_AUTH_SOURCE=admin
# DB_REPLICA_SET=
# DB_RETRY_WRITES=true
# DB_SSL=
# DB_TLS=
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Redis (optional but recommended)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Mail (optional, required for email OTP / notifications)
EMAIL_USER=
EMAIL_PASS=

# Optional integrations
GOOGLE_CLIENT_ID=
VUE_APP_CLIENTID=
APP_BASE_URL=https://researchproposal.mfu.ac.th
COLLAB_CONFIRM_BASE_URL=https://researchproposal.mfu.ac.th
COLLAB_CONFIRM_TOKEN_TTL_HOURS=168
TRUST_DEVICE_DAYS=30

# Report export cleanup
REPORT_EXPORT_RETENTION_HOURS=24
